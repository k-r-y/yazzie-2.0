# Application Environment
APP_ENV=development

# Database Settings
DB_HOST=localhost
DB_NAME=yazzie
DB_USER=root
DB_PASS=

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Email SMTP Settings
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=yazziecateringservices@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=yazziecateringservices@gmail.com
MAIL_FROM_NAME="Yazzies Catering Services"
MAIL_ENABLED=true

# SMS Settings
SMS_API_KEY=your_semaphore_api_key
SMS_SENDER=YAZZIES
SMS_ENABLED=false

# PayMongo Payment Gateway (Phase 3)
# Get your webhook signing secret from: https://dashboard.paymongo.com/developers/webhooks
PAYMONGO_WEBHOOK_SECRET_KEY=whsk_your_signing_secret_here
PAYMONGO_PUBLIC_KEY=pk_test_your_public_key_here
PAYMONGO_SECRET_KEY=sk_test_your_secret_key_here
